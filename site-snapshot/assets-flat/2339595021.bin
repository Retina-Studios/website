<style id="stylableCss_qoofk">/* END STYLABLE DIRECTIVE RULES */

#comp-m7aecmv8 .style-m7boervh__root{
    -st-extends: StylableButton;
    transition: all 0.2s ease, visibility 0s;
    background: #F9D342
}

/* START STYLABLE DIRECTIVE RULES */

#comp-m7aecmv8 .style-m7boervh__root:hover {
    background: #000000;
}

#comp-m7aecmv8 .style-m7boervh__root:hover .StylableButton2545352419__label {
    color: #FFFFFF;
}

#comp-m7aecmv8 .style-m7boervh__root:disabled{
    background: #E2E2E2
}

#comp-m7aecmv8 .style-m7boervh__root:disabled .StylableButton2545352419__label{
    color: #8F8F8F
}

#comp-m7aecmv8 .style-m7boervh__root:disabled .StylableButton2545352419__icon{
    fill: #8F8F8F
}

