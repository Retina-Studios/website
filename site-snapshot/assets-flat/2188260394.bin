<style id="stylableCss_afs34">/* END STYLABLE DIRECTIVE RULES */

#comp-m71twlup2 .style-m7ivtt0o__root{
    -st-extends: StylableButton;
    transition: all 0.2s ease, visibility 0s;
    padding: 10px;
    background: #FF4040;
    border-radius: 26px
}

